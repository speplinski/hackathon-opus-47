# Copy to `.env` (gitignored) and fill in the values below.
# Never commit `.env` — these values are author-local.

# Salt for `author_hash = sha256(salt || userName)` in the review corpus.
# 32 bytes, hex-encoded (64 hex chars). Generated automatically by
# `scripts/collect_reviews.py` on first run and appended below; leave the
# template line commented out so the first run does not create a duplicate.
# See docs/SECURITY.md V-09 for the threat model.
# DUOLINGO_REVIEW_SALT=<auto-generated on first run>

# Anthropic API key for live-mode `claude_client.py`. Not needed for
# replay mode (which reads from the committed replay log).
ANTHROPIC_API_KEY=
